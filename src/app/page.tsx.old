'use client';

import { useState, useRef, useEffect, useCallback } from 'react';
import type { ChangeEvent } from 'react';
import { processAndSaveInvoice } from '@/app/actions';
import type { InvoiceProcessingResult, ValidatedData } from '@/lib/types';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '@/components/ui/table';
import { Alert, AlertDescription, AlertTitle } from '@/components/ui/alert';
import { useToast } from '@/hooks/use-toast';
import { exportToCsv, exportToJson } from '@/lib/utils';
import Image from 'next/image';
import {
  ShieldCheck, Upload, LoaderCircle, XCircle, FileText,
  ArrowLeft, History, Copy, Download, Printer, CheckCircleIcon, Camera,
} from 'lucide-react';
import { ThemeToggle } from '@/components/ThemeToggle';
import { useLocalStorage } from '@/hooks/use-local-storage';
import { Separator } from '@/components/ui/separator';
import { Input } from '@/components/ui/input';
import { Skeleton } from '@/components/ui/skeleton';
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogFooter,
  DialogClose,
} from '@/components/ui/dialog';

import * as pdfjsLib from 'pdfjs-dist';
pdfjsLib.GlobalWorkerOptions.workerSrc = `//cdnjs.cloudflare.com/ajax/libs/pdf.js/${pdfjsLib.version}/pdf.worker.min.js`;


type Stage = 'initial' | 'processing' | 'results';

const AppHeader = ({ toggleHistory, historyOpen }: { toggleHistory: () => void; historyOpen: boolean }) => (
  <header className="p-4 border-b bg-card no-print">
    <div className="container mx-auto flex items-center justify-between gap-3">
      <div className="flex items-center gap-3">
        <ShieldCheck className="h-8 w-8 text-primary" />
        <h1 className="text-2xl font-bold text-foreground">InvoiceGuard AI</h1>
      </div>
      <div className="flex items-center gap-2">
        <Button variant={historyOpen ? "secondary" : "ghost"} size="icon" onClick={toggleHistory}>
          <History className="h-5 w-5" />
          <span className="sr-only">Toggle History</span>
        </Button>
        <ThemeToggle />
      </div>
    </div>
  </header>
);

const InitialView = ({ onUploadClick, onCameraClick }: { onUploadClick: () => void; onCameraClick: () => void; }) => (
  <Card className="w-full max-w-lg animate-fade-in-up">
    <CardHeader className="text-center">
      <CardTitle className="text-3xl font-bold">AI Invoice Error Checker</CardTitle>
      <CardDescription className="pt-2">
        Upload or take a photo of a sales invoice (JPG, PNG, PDF). The AI will find errors for you.
        <br />
        <span className="text-xs text-muted-foreground mt-2 block">(Use shortcuts: 'u' for upload, 'c' for camera)</span>
      </CardDescription>
    </CardHeader>
    <CardContent className="flex flex-col sm:flex-row gap-4">
      <Button size="lg" onClick={onCameraClick} variant="outline" className="h-24 flex-1 flex-col gap-2 text-base">
        <Camera className="h-8 w-8" />
        Take Photo
      </Button>
      <Button size="lg" onClick={onUploadClick} className="h-24 flex-1 flex-col gap-2 text-base bg-accent hover:bg-accent/90 text-accent-foreground">
        <Upload className="h-8 w-8" />
        Upload File
      </Button>
    </CardContent>
  </Card>
);

const ProcessingSkeleton = () => (
    <div className="w-full max-w-4xl animate-fade-in-up space-y-6">
        <div className="flex justify-between items-center">
            <Skeleton className="h-10 w-48" />
             <div className="flex gap-2">
                <Skeleton className="h-10 w-24" />
                <Skeleton className="h-10 w-24" />
             </div>
        </div>
        <Skeleton className="h-24 w-full" />
        <div className="grid md:grid-cols-2 gap-6">
            <Card>
                <CardHeader><Skeleton className="h-8 w-3/4" /></CardHeader>
                <CardContent className="space-y-4">
                    <Skeleton className="h-6 w-full" />
                    <Skeleton className="h-6 w-3/4" />
                    <Skeleton className="h-6 w-1/2" />
                    <div className="pt-4 border-t"><Skeleton className="h-20 w-full" /></div>
                    <div className="pt-4 border-t"><Skeleton className="h-24 w-full" /></div>
                </CardContent>
            </Card>
            <Card>
                <CardHeader><Skeleton className="h-8 w-1/2" /></CardHeader>
                <CardContent><Skeleton className="w-full aspect-[4/5]" /></CardContent>
            </Card>
        </div>
    </div>
);


const ResultsView = ({ result, onReset, onUpdate }: { result: InvoiceProcessingResult; onReset: () => void; onUpdate: (id: string, data: ValidatedData) => void }) => {
  const { toast } = useToast();
  const [editedData, setEditedData] = useState<ValidatedData>(JSON.parse(JSON.stringify(result.validatedData)));
  const [isEditing, setIsEditing] = useState(false);

  const handleFieldChange = (field: keyof Omit<ValidatedData, 'items'>, value: string) => {
    setEditedData(prev => ({ ...prev, [field]: value }));
    if(!isEditing) setIsEditing(true);
  };
  
  const handleItemChange = (index: number, field: keyof ValidatedData['items'][0], value: string) => {
    setEditedData(prev => {
        const newItems = [...(prev.items || [])];
        newItems[index] = { ...newItems[index], [field]: value };
        return { ...prev, items: newItems };
    });
    if(!isEditing) setIsEditing(true);
  };

  const copyErrors = () => {
    navigator.clipboard.writeText(result.errors.join('\n'));
    toast({ title: "Copied!", description: "Validation errors copied to clipboard." });
  };
  
  const handleUpdate = () => {
    const numericData = {
        ...editedData,
        items: editedData.items?.map(item => ({
            ...item,
            quantity: Number(item.quantity) || undefined,
            unit_price: Number(item.unit_price) || undefined,
            line_total: Number(item.line_total) || undefined,
        })),
        subtotal: Number(editedData.subtotal) || undefined,
        tax: Number(editedData.tax) || undefined,
        total: Number(editedData.total) || undefined,
    }
    onUpdate(result.id, numericData);
    setIsEditing(false);
  }

  return (
  <div className="w-full max-w-6xl animate-fade-in-up space-y-6 print-container">
    <div className="flex justify-between items-center no-print">
      <Button onClick={onReset} variant="outline">
        <ArrowLeft className="mr-2 h-4 w-4" /> Scan Another Invoice
      </Button>
      <div className="flex items-center gap-2">
        {isEditing && <Button onClick={handleUpdate}><CheckCircleIcon className="mr-2 h-4 w-4" /> Save Corrections</Button>}
        <Button variant="outline" onClick={() => exportToJson(editedData)}><Download className="mr-2 h-4 w-4" /> JSON</Button>
        <Button variant="outline" onClick={() => exportToCsv(editedData)}><Download className="mr-2 h-4 w-4" /> CSV</Button>
        <Button variant="outline" onClick={() => window.print()}><Printer className="mr-2 h-4 w-4" /> Print</Button>
      </div>
    </div>
    
    <Card className={`print-card ${result.isValid ? 'border-green-500' : 'border-red-500'}`}>
      <CardHeader>
        <div className="flex items-center gap-3">
          {result.isValid ? (
            <CheckCircleIcon className="h-8 w-8 text-green-500" />
          ) : (
            <XCircle className="h-8 w-8 text-red-500" />
          )}
          <div>
            <CardTitle className={`text-3xl font-bold ${result.isValid ? 'text-green-600' : 'text-red-600'}`}>
              {result.isValid ? 'Invoice Verified' : 'Errors Detected'}
            </CardTitle>
            <CardDescription>
              {result.isValid ? 'The invoice has been successfully validated and stored.' : 'Please review the errors and make corrections if needed.'}
            </CardDescription>
          </div>
        </div>
      </CardHeader>
      {!result.isValid && result.errors.length > 0 && (
        <CardContent>
          <Alert variant="destructive">
            <div className="flex justify-between items-center">
                <AlertTitle className="text-xl font-bold">Validation Errors</AlertTitle>
                <Button variant="ghost" size="sm" onClick={copyErrors} className="no-print"><Copy className="mr-2 h-4 w-4" />Copy</Button>
            </div>
            <AlertDescription>
              <ul className="list-disc pl-5 space-y-2 mt-2 text-base">
                {result.errors.map((error, index) => (
                  <li key={index}>{error}</li>
                ))}
              </ul>
            </AlertDescription>
          </Alert>
        </CardContent>
      )}
    </Card>

    <div className="grid lg:grid-cols-2 gap-6">
      <Card className="print-card">
        <CardHeader>
          <CardTitle className="flex items-center gap-2"><FileText /> Extracted Invoice Data</CardTitle>
        </CardHeader>
        <CardContent className="space-y-4">
            <div className="grid grid-cols-2 gap-4">
                <div className="space-y-1">
                    <label className="text-sm font-medium text-muted-foreground">Invoice Number</label>
                    <Input value={editedData.invoice_number || ''} onChange={e => handleFieldChange('invoice_number', e.target.value)} />
                </div>
                <div className="space-y-1">
                    <label className="text-sm font-medium text-muted-foreground">Invoice Date</label>
                    <Input value={editedData.date || ''} onChange={e => handleFieldChange('date', e.target.value)} />
                </div>
            </div>
            <div className="space-y-1">
                <label className="text-sm font-medium text-muted-foreground">Customer Name</label>
                <Input value={editedData.customer_name || ''} onChange={e => handleFieldChange('customer_name', e.target.value)} />
            </div>

          <h4 className="font-semibold pt-4 border-t">Items</h4>
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>Name</TableHead>
                <TableHead className="w-24 text-right">Qty</TableHead>
                <TableHead className="w-32 text-right">Price</TableHead>
                <TableHead className="w-32 text-right">Total</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              {editedData.items?.map((item, index) => (
                <TableRow key={index}>
                  <TableCell><Input value={item.name || ''} onChange={e => handleItemChange(index, 'name', e.target.value)} className="h-8"/></TableCell>
                  <TableCell><Input value={item.quantity ?? ''} onChange={e => handleItemChange(index, 'quantity', e.target.value)} className="h-8 text-right"/></TableCell>
                  <TableCell><Input value={item.unit_price ?? ''} onChange={e => handleItemChange(index, 'unit_price', e.target.value)} className="h-8 text-right"/></TableCell>
                  <TableCell><Input value={item.line_total ?? ''} onChange={e => handleItemChange(index, 'line_total', e.target.value)} className="h-8 text-right"/></TableCell>
                </TableRow>
              ))}
            </TableBody>
          </Table>

            <div className="grid grid-cols-3 gap-4 pt-4 border-t">
                 <div className="space-y-1">
                    <label className="text-sm font-medium text-muted-foreground">Subtotal</label>
                    <Input value={editedData.subtotal ?? ''} onChange={e => handleFieldChange('subtotal', e.target.value)} className="text-right font-semibold" />
                </div>
                 <div className="space-y-1">
                    <label className="text-sm font-medium text-muted-foreground">Tax</label>
                    <Input value={editedData.tax ?? ''} onChange={e => handleFieldChange('tax', e.target.value)} className="text-right font-semibold"/>
                </div>
                 <div className="space-y-1">
                    <label className="text-sm font-medium text-muted-foreground">Total</label>
                    <Input value={editedData.total ?? ''} onChange={e => handleFieldChange('total', e.target.value)} className="text-right font-bold text-lg"/>
                </div>
            </div>
        </CardContent>
      </Card>
      
      <Tabs defaultValue="image" className="h-fit">
        <TabsList className="grid w-full grid-cols-2 no-print">
            <TabsTrigger value="image">Invoice Preview</TabsTrigger>
            <TabsTrigger value="ocr">AI Analysis</TabsTrigger>
        </TabsList>
        <TabsContent value="image">
            <Card className="print-card">
                <CardContent className="p-4">
                {result.processedImageDataUri && (
                    <Image
                        src={result.processedImageDataUri}
                        alt="Processed invoice"
                        width={800}
                        height={1120}
                        className="rounded-md object-contain shadow-md mx-auto"
                    />
                )}
                </CardContent>
            </Card>
        </TabsContent>
        <TabsContent value="ocr">
            <Card className="print-card">
                 <CardContent className="p-4">
                     <p className="text-sm whitespace-pre-wrap font-mono bg-muted p-4 rounded-md max-h-[560px] overflow-auto">
                        {result.ocrText}
                     </p>
                </CardContent>
            </Card>
        </TabsContent>
        </Tabs>
    </div>
  </div>
)};

const HistorySidebar = ({
  history,
  onSelect,
  onClear,
  isOpen
}: {
  history: InvoiceProcessingResult[];
  onSelect: (result: InvoiceProcessingResult) => void;
  onClear: () => void;
  isOpen: boolean;
}) => {
    if(!isOpen) return null;
    return (
        <aside className="w-80 border-l p-4 flex flex-col gap-4 no-print animate-fade-in-left">
            <div className="flex justify-between items-center">
                <h2 className="text-lg font-semibold">Scan History</h2>
                {history.length > 0 && <Button variant="ghost" size="sm" onClick={onClear}>Clear</Button>}
            </div>
            <Separator />
            {history.length === 0 ? (
                <div className="text-center text-muted-foreground mt-8">
                    <p>No scans in this session yet.</p>
                </div>
            ) : (
                <div className="flex flex-col-reverse gap-2 overflow-y-auto">
                    {history.map((item) => (
                        <button key={item.id} onClick={() => onSelect(item)} className="text-left">
                             <Card className="hover:bg-muted transition-colors">
                                <CardContent className="p-3 flex items-start gap-3">
                                    <Image src={item.originalImageDataUri} alt="Thumbnail" width={60} height={80} className="rounded-sm object-cover" />
                                    <div className="truncate">
                                        <p className="font-semibold truncate">{item.validatedData.customer_name || 'Unknown Customer'}</p>
                                        <p className="text-sm text-muted-foreground">Inv: {item.validatedData.invoice_number || 'N/A'}</p>
                                        <p className={`text-sm font-bold ${item.status === 'verified' ? 'text-green-600' : item.status === 'error' ? 'text-red-600' : 'text-yellow-600'}`}>{item.status.charAt(0).toUpperCase() + item.status.slice(1)}</p>
                                    </div>
                                </CardContent>
                            </Card>
                        </button>
                    ))}
                </div>
            )}
        </aside>
    );
};

const CameraView = ({ onCapture, onOpenChange }: { onCapture: (dataUri: string) => void, onOpenChange: (isOpen: boolean) => void }) => {
    const videoRef = useRef<HTMLVideoElement>(null);
    const canvasRef = useRef<HTMLCanvasElement>(null);
    const [hasCameraPermission, setHasCameraPermission] = useState<boolean | null>(null);
    const { toast } = useToast();

    useEffect(() => {
        let stream: MediaStream;

        const getCameraPermission = async () => {
            try {
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    throw new Error('Camera not supported by this browser.');
                }
                stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                setHasCameraPermission(true);

                if (videoRef.current) {
                    videoRef.current.srcObject = stream;
                }
            } catch (error: any) {
                console.error('Error accessing camera:', error);
                setHasCameraPermission(false);
                toast({
                    variant: 'destructive',
                    title: 'Camera Access Denied',
                    description: error.message || 'Please enable camera permissions in your browser settings.',
                });
            }
        };

        getCameraPermission();

        return () => {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }
        };
    }, [toast]);
    
    const handleCapture = () => {
        if (videoRef.current && canvasRef.current) {
            const video = videoRef.current;
            const canvas = canvasRef.current;
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            const context = canvas.getContext('2d');
            context?.drawImage(video, 0, 0, video.videoWidth, video.videoHeight);
            const dataUri = canvas.toDataURL('image/jpeg');
            onCapture(dataUri);
        }
    };

    return (
        <DialogContent className="sm:max-w-[625px]">
            <DialogHeader>
                <DialogTitle>Take Photo of Invoice</DialogTitle>
            </DialogHeader>
            <div className="relative">
                <video ref={videoRef} className="w-full aspect-video rounded-md bg-muted" autoPlay muted playsInline />
                <canvas ref={canvasRef} className="hidden" />
                
                {hasCameraPermission === false && (
                    <div className="absolute inset-0 flex items-center justify-center bg-black/80 rounded-md">
                        <Alert variant="destructive" className="w-auto">
                            <AlertTitle>Camera Access Required</AlertTitle>
                            <AlertDescription>
                                Please allow camera access to use this feature.
                            </AlertDescription>
                        </Alert>
                    </div>
                )}
                {hasCameraPermission === null && (
                     <div className="absolute inset-0 flex items-center justify-center bg-black/80 rounded-md">
                        <LoaderCircle className="h-10 w-10 text-white animate-spin" />
                    </div>
                )}
            </div>
            <DialogFooter className="sm:justify-between">
                <DialogClose asChild>
                    <Button type="button" variant="secondary">Cancel</Button>
                </DialogClose>
                <Button type="button" onClick={handleCapture} disabled={!hasCameraPermission}>
                    <Camera className="mr-2" /> Capture
                </Button>
            </DialogFooter>
        </DialogContent>
    );
};

export default function HomePage() {
  const [stage, setStage] = useState<Stage>('initial');
  const [result, setResult] = useState<InvoiceProcessingResult | null>(null);
  const { toast } = useToast();
  const fileInputRef = useRef<HTMLInputElement>(null);
  const [history, setHistory] = useLocalStorage<InvoiceProcessingResult[]>('invoice-history', []);
  const [historyOpen, setHistoryOpen] = useState(false);
  const [isCameraOpen, setIsCameraOpen] = useState(false);

  const addToHistory = (newItem: InvoiceProcessingResult) => {
    setHistory(prev => [newItem, ...prev.slice(0, 9)]);
  };
  
  const updateHistoryItem = (updatedItem: InvoiceProcessingResult) => {
      setHistory(prev => prev.map(item => item.id === updatedItem.id ? updatedItem : item));
  };
  
  const resetState = () => {
    setStage('initial');
    setResult(null);
    if(fileInputRef.current) fileInputRef.current.value = '';
  };

  const processInvoice = async (imageDataUri: string) => {
    try {
      const res = await processAndSaveInvoice(imageDataUri);
      setResult(res);
      addToHistory(res);
      setStage('results');
    } catch (e) {
      console.error(e);
      toast({
        variant: "destructive",
        title: "AI Processing Failed",
        description: e instanceof Error ? e.message : "An unknown error occurred.",
      });
      resetState();
    }
  }

  const handleFileChange = async (event: ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];
    if (!file) return;

    setStage('processing');
    setResult(null);

    let originalImageDataUri: string;

    try {
        if (file.type === 'application/pdf') {
            const pdfData = await file.arrayBuffer();
            const pdf = await pdfjsLib.getDocument(pdfData).promise;
            const page = await pdf.getPage(1);
            const viewport = page.getViewport({ scale: 2.0 });
            const canvas = document.createElement('canvas');
            canvas.height = viewport.height;
            canvas.width = viewport.width;
            const context = canvas.getContext('2d');
            if(!context) throw new Error("Could not get canvas context for PDF preview.");
            await page.render({ canvasContext: context, viewport: viewport }).promise;
            originalImageDataUri = canvas.toDataURL('image/jpeg', 0.95);
        } else {
            originalImageDataUri = await new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = (e) => resolve(e.target?.result as string);
                reader.onerror = (e) => reject(new Error("Failed to read file"));
                reader.readAsDataURL(file);
            });
        }
    } catch(e: any) {
        console.error("File Processing Error:", e);
        toast({ variant: "destructive", title: "File Processing Failed", description: e.message || "Could not read the selected file." });
        resetState();
        return;
    }

    await processInvoice(originalImageDataUri);
  };
  
  const handlePhotoCapture = async (imageDataUri: string) => {
    setIsCameraOpen(false);
    setStage('processing');
    setResult(null);
    await processInvoice(imageDataUri);
  };

  const handleUpdateInvoice = (id: string, data: ValidatedData) => {
    try {
        toast({ title: "Success", description: "Corrections saved to session history." });
        if(result){
            const updatedResult = { ...result, validatedData: data, status: 'corrected' as const };
            setResult(updatedResult);
            updateHistoryItem(updatedResult);
        }
    } catch (e) {
        console.error(e);
        toast({ variant: "destructive", title: "Update Failed", description: e instanceof Error ? e.message : "An unknown error occurred." });
    }
  }
  
  const handleHistorySelect = (selectedResult: InvoiceProcessingResult) => {
      setResult(selectedResult);
      setStage('results');
  };

  const handleClearHistory = () => {
      setHistory([]);
      toast({ title: "History Cleared" });
  }

  const handleCameraClick = () => setIsCameraOpen(true);

  const handleKeyDown = useCallback((event: KeyboardEvent) => {
    if (stage !== 'initial') return;
    const key = event.key.toLowerCase();
    if (key === 'u') {
        fileInputRef.current?.click();
    }
    if (key === 'c') {
        handleCameraClick();
    }
  }, [stage]);

  useEffect(() => {
    window.addEventListener('keydown', handleKeyDown);
    return () => {
        window.removeEventListener('keydown', handleKeyDown);
    };
  }, [handleKeyDown]);

  return (
    <div className="flex flex-col min-h-svh">
      <AppHeader toggleHistory={() => setHistoryOpen(prev => !prev)} historyOpen={historyOpen} />
      <div className="flex flex-1">
        <main className="flex-1 flex flex-col items-center justify-start container mx-auto p-4 pt-12 md:p-8 md:pt-16">
            {stage === 'initial' && (
            <InitialView
                onUploadClick={() => fileInputRef.current?.click()}
                onCameraClick={handleCameraClick}
            />
            )}
            {stage === 'processing' && <ProcessingSkeleton />}
            {stage === 'results' && result && <ResultsView result={result} onReset={resetState} onUpdate={handleUpdateInvoice} />}
        </main>
        <HistorySidebar history={history} onSelect={handleHistorySelect} onClear={handleClearHistory} isOpen={historyOpen}/>
      </div>

      <Dialog open={isCameraOpen} onOpenChange={setIsCameraOpen}>
        <CameraView onCapture={handlePhotoCapture} onOpenChange={setIsCameraOpen} />
      </Dialog>

      <input
        type="file"
        ref={fileInputRef}
        onChange={handleFileChange}
        accept="application/pdf,image/png,image/jpeg"
        className="hidden"
      />
    </div>
  );
}
